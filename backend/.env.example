# =============================================================================
# Alufit API — copy to .env and adjust (never commit .env)
# Load order: pydantic reads .env from the process cwd (run uvicorn from backend/)
# =============================================================================

# --- Core ---
DATABASE_URL=sqlite:///./alufit.db
SECRET_KEY=change-me-in-production-use-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# --- Redis (Celery broker/backend if you use app.worker.celery_app) ---
REDIS_URL=redis://localhost:6379/0

# --- File storage ---
# local = files under LOCAL_STORAGE_PATH (default). s3 = MinIO/S3-compatible.
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=uploads
# If STORAGE_BACKEND=s3, set these and ensure the bucket exists:
# S3_ENDPOINT_URL=http://127.0.0.1:9000
# S3_ACCESS_KEY=minio
# S3_SECRET_KEY=minio12345
# S3_BUCKET=alufit
# S3_REGION=us-east-1

# --- Public URL & n8n / Gmail automation ---
# URL n8n must POST to for BOQ approval (must be reachable from the internet for hosted n8n).
# Prefer this explicit URL over PUBLIC_APP_URL when both matter.
N8N_BOQ_CALLBACK_URL=
# If N8N_BOQ_CALLBACK_URL is empty, callback becomes PUBLIC_APP_URL + /api/approval
PUBLIC_APP_URL=
# Optional: n8n “Webhook” URL — Alufit POSTs here when a BOQ is submitted for customer approval
N8N_BOQ_SUBMITTED_WEBHOOK_URL=
# Must match the header X-Webhook-Secret n8n sends when POSTing approval to /api/approval
CUSTOMER_APPROVAL_WEBHOOK_SECRET=dev-n8n-secret-change-in-production

# --- BOQ notification emails (optional) ---
# Required for send_boq_submitted_for_approval_email after upload/submit; empty = no email (logs warning)
BOQ_SUBMIT_NOTIFY_EMAIL=
# Line-addition approval emails; if empty, code may fall back to BOQ_SUBMIT_NOTIFY_EMAIL
BOQ_LINE_ADDITIONS_NOTIFY_EMAIL=

# --- SMTP (required only if you want outbound BOQ emails) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# --- RBAC: map email domain -> role (JSON object string) ---
# Roles used in app: contracts, design, qs
EMAIL_DOMAIN_ROLE_MAPPING='{"contracts.com": "contracts", "design.com": "design", "qs.com": "qs"}'
