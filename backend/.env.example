DATABASE_URL=sqlite:///./alufit.db
SECRET_KEY=dev-secret-change-in-production

# File uploads: local (default) stores under backend/uploads/ — no MinIO required.

# RBAC: Email domain to role mapping (JSON format)
# Assign default roles based on email domains
# Example: '{"contracts.com": "contracts", "design.com": "design", "qs.com": "qs"}'
# If no mapping matches, default role is 'contracts'
EMAIL_DOMAIN_ROLE_MAPPING='{"contracts.com": "contracts", "design.com": "design", "qs.com": "qs"}'

# STORAGE_BACKEND=s3
# S3_ENDPOINT_URL=http://127.0.0.1:9000
# S3_ACCESS_KEY=minio
# S3_SECRET_KEY=minio12345
# S3_BUCKET=alufit
# LOCAL_STORAGE_PATH=uploads

# Start API (example: uvicorn app.main:app --reload --host 127.0.0.1 --port 8003)

# --- n8n (hosted): must use your public API URL, not localhost ---
# Full URL n8n will POST to (HTTPS recommended):
N8N_BOQ_CALLBACK_URL=https://api.your-domain.com/api/approval
# Optional: if N8N_BOQ_CALLBACK_URL is unset, callback becomes PUBLIC_APP_URL + /api/approval
# PUBLIC_APP_URL=https://api.your-domain.com
# Local dev only (n8n on same machine): e.g. http://127.0.0.1:8001/api/approval
# n8n Webhook node production URL (Alufit POSTs here when a BOQ is submitted for approval)
N8N_BOQ_SUBMITTED_WEBHOOK_URL=
# Same value in n8n for the callback HTTP node header X-Webhook-Secret
CUSTOMER_APPROVAL_WEBHOOK_SECRET=dev-n8n-secret-change-in-production

# BOQ submit notification (contracts: new BOQ upload or submit for customer approval).
# The uploaded spreadsheet is saved under LOCAL_STORAGE_PATH (or S3) and attached to this email.
BOQ_SUBMIT_NOTIFY_EMAIL=yeshwanthsh128@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
# App accepts SMTP_USER or SMTP_USERNAME (same value)
SMTP_USER=your-account@gmail.com
SMTP_PASSWORD=your-app-password
# Sender shown to recipient (use your provider’s authorized address / alias)
SMTP_FROM_EMAIL=support@exora.solutions
