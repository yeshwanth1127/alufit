# Backend: copy to backend/.env or export env vars. Run uvicorn from the `backend/` folder:
#   uvicorn app.main:app --reload --host 127.0.0.1 --port 8003
DATABASE_URL=sqlite:///./alufit.db
SECRET_KEY=change-me-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Celery (optional; ERP jobs run synchronously via API without a worker)
REDIS_URL=redis://localhost:6379/0

# S3-compatible storage for document attachments (optional for local dev; uploads fail if unreachable)
S3_ENDPOINT_URL=http://127.0.0.1:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_BUCKET=alufit
S3_REGION=us-east-1

# Frontend (Vite): copy to frontend/.env.development — use /api (proxies to API on port 8003)
# Or call the API directly: VITE_API_URL=http://127.0.0.1:8003
VITE_API_URL=/api

# Backend (see backend/.env.example): set N8N_BOQ_CALLBACK_URL to your public HTTPS API URL for hosted n8n (not localhost)
